{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "standbyModeEnabled": {
          "type": "checkbox",
          "label": "Standby-Modus / Vorsommer-Modus aktiv",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "enableCirculationControl": {
          "type": "checkbox",
          "label": "Umwälzpumpe aktiv",
          "newLine": true,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "enablePhControl": {
          "type": "checkbox",
          "label": "PH Steuerung aktiv",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "enableHeatpumpControl": {
          "type": "checkbox",
          "label": "Wärmepumpensteuerung aktiv",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "enableChlorControl": {
          "type": "checkbox",
          "label": "Chlorsteuerung aktiv",
          "newLine": false,
          "sm": 12,
          "md": 3,
          "lg": 3
        },
        "standbyRunTime": {
          "type": "text",
          "label": "Standby-Uhrzeit (HH:MM)",
          "newLine": true,
          "help": "Täglicher Kurzlauf der Umwälzpumpe, z. B. 12:00",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "standbyPumpDurationSec": {
          "type": "number",
          "label": "Standby-Laufzeit Umwälzpumpe (Sekunden)",
          "newLine": false,
          "help": "Standard 30 Sekunden",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Prüfintervall (Minuten)",
          "newLine": true,
          "help": "Wie oft alle Werte neu gelesen und die HTML-Ausgabe aktualisiert wird.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "trendHeader": {
          "type": "header",
          "text": "Trend aus History",
          "size": 2
        },
        "trendHistoryInstance": {
          "type": "text",
          "label": "History-Instanz",
          "help": "Standard history.0. Wird für die 1h-Tendenz verwendet.",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "trendWindowMin": {
          "type": "number",
          "label": "Trendfenster (Minuten)",
          "help": "Standard 60 Minuten.",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "trendSmoothMin": {
          "type": "number",
          "label": "Glättung (Minuten)",
          "help": "Standard 5 Minuten. Vergleicht Mittelwert der letzten x Minuten mit dem Fenster vor 60 Minuten.",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "trendTolerancePh": {
          "type": "text",
          "label": "Toleranz pH",
          "help": "Standard 0.03",
          "newLine": false,
          "sm": 12,
          "md": 2,
          "lg": 2
        },
        "trendToleranceOrp": {
          "type": "number",
          "label": "Toleranz ORP",
          "help": "Standard 15",
          "newLine": false,
          "sm": 12,
          "md": 2,
          "lg": 2
        },
        "trendToleranceTemp": {
          "type": "text",
          "label": "Toleranz Temperatur",
          "help": "Standard 0.3 °C",
          "newLine": false,
          "sm": 12,
          "md": 2,
          "lg": 2
        },
        "poolDiameterM": {
          "type": "text",
          "label": "Pooldurchmesser (m)",
          "newLine": false,
          "help": "z. B. 4.60 oder 4,60",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "poolWaterHeightM": {
          "type": "text",
          "label": "Wasserhöhe (m)",
          "newLine": true,
          "help": "z. B. 1.10 oder 1,10",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "poolVolumeM3": {
          "type": "text",
          "label": "Poolvolumen (m³)",
          "newLine": false,
          "help": "Wird beim Adapterstart / Poll neu berechnet.",
          "disabled": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      }
    },
    "circulation": {
      "type": "panel",
      "label": "UMWÄLZPUMPE",
      "items": {
        "headerPump": {
          "type": "header",
          "text": "Aktor & Schreibweise",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "circulationPumpSocketStateId": {
          "type": "objectId",
          "label": "Umwälzpumpe",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "objectTypes": [
            "state"
          ]
        },
        "circulationPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat Umwälzpumpe",
          "newLine": false,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "headerHeartbeat": {
          "type": "header",
          "text": "Erreichbarkeit",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "circulationPumpHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung, z. B. ein regelmäßig aktualisierter Temperatur- oder Status-State."
        },
        "circulationPumpHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": false,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird das Gerät als veraltet markiert. 0 = keine Prüfung.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "headerWindows": {
          "type": "header",
          "text": "Zeitfenster",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "pumpWindow1Start": {
          "type": "text",
          "label": "Zeitfenster 1 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pumpWindow1End": {
          "type": "text",
          "label": "Zeitfenster 1 Ende",
          "newLine": false,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pumpWindow2Start": {
          "type": "text",
          "label": "Zeitfenster 2 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pumpWindow2End": {
          "type": "text",
          "label": "Zeitfenster 2 Ende",
          "newLine": false,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "weekendHeader": {
          "type": "header",
          "text": "Wochenende optional abweichend"
        },
        "pumpSaturdayCustomEnabled": {
          "type": "checkbox",
          "label": "Samstag eigene Zeiten verwenden",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pumpSaturdayWindow1Start": {
          "type": "text",
          "label": "Samstag Fenster 1 Start (HH:MM)",
          "newLine": true,
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSaturdayCustomEnabled !== true"
        },
        "pumpSaturdayWindow1End": {
          "type": "text",
          "label": "Samstag Fenster 1 Ende (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSaturdayCustomEnabled !== true"
        },
        "pumpSaturdayWindow2Start": {
          "type": "text",
          "label": "Samstag Fenster 2 Start (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSaturdayCustomEnabled !== true"
        },
        "pumpSaturdayWindow2End": {
          "type": "text",
          "label": "Samstag Fenster 2 Ende (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSaturdayCustomEnabled !== true"
        },
        "pumpSundayCustomEnabled": {
          "type": "checkbox",
          "label": "Sonntag eigene Zeiten verwenden",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "pumpSundayWindow1Start": {
          "type": "text",
          "label": "Sonntag Fenster 1 Start (HH:MM)",
          "newLine": true,
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSundayCustomEnabled !== true"
        },
        "pumpSundayWindow1End": {
          "type": "text",
          "label": "Sonntag Fenster 1 Ende (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSundayCustomEnabled !== true"
        },
        "pumpSundayWindow2Start": {
          "type": "text",
          "label": "Sonntag Fenster 2 Start (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSundayCustomEnabled !== true"
        },
        "pumpSundayWindow2End": {
          "type": "text",
          "label": "Sonntag Fenster 2 Ende (HH:MM)",
          "sm": 12,
          "md": 3,
          "lg": 3,
          "hidden": "data.pumpSundayCustomEnabled !== true"
        }
      },
      "hidden": "data.enableCirculationControl === false"
    },
    "chlor": {
      "type": "panel",
      "label": "CHLOR",
      "items": {
        "headerSensorAct": {
          "type": "header",
          "text": "Sensor & Aktor",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "orpStateId": {
          "type": "objectId",
          "label": "State-ID ORP",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "objectTypes": [
            "state"
          ]
        },
        "chlorinatorSocketStateId": {
          "type": "objectId",
          "label": "Chlorinator",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "objectTypes": [
            "state"
          ]
        },
        "chlorinatorWriteMode": {
          "type": "select",
          "label": "Schreibformat Chlorinator",
          "newLine": true,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "chlorPumpStartDelaySec": {
          "type": "number",
          "label": "Verzögerung nach Pumpenstart (Sekunden)",
          "newLine": false,
          "min": 0,
          "help": "Der Chlorinator darf erst nach dieser Verzögerung nach dem Einschalten der Umwälzpumpe aktiv werden. 0 = ohne Verzögerung.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "headerChlHb": {
          "type": "header",
          "text": "Erreichbarkeit",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "chlorinatorHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung des Chlorinators."
        },
        "chlorinatorHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": false,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird der Chlorinator als veraltet markiert. 0 = keine Prüfung.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "headerOrp": {
          "type": "header",
          "text": "ORP-Grenzen",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "size": 2
        },
        "orpSetpoint": {
          "type": "number",
          "label": "ORP Sollwert",
          "newLine": true,
          "sm": 12,
          "md": 4,
          "lg": 4
        },
        "orpOnThreshold": {
          "type": "number",
          "label": "ORP Einschaltgrenze",
          "newLine": false,
          "help": "Wenn ORP kleiner oder gleich diesem Wert ist, darf der Chlorinator einschalten.",
          "sm": 12,
          "md": 4,
          "lg": 4
        },
        "orpOffThreshold": {
          "type": "number",
          "label": "ORP Ausschaltgrenze",
          "newLine": false,
          "help": "Wenn ORP größer als dieser Wert ist, wird der Chlorinator ausgeschaltet.",
          "sm": 12,
          "md": 4,
          "lg": 4
        }
      },
      "hidden": "data.enableChlorControl === false"
    },
    "ph": {
      "type": "panel",
      "label": "PH",
      "items": {
        "phSensorsHeader": {
          "type": "header",
          "text": "Sensordaten und Freigaben",
          "size": 2
        },
        "phStateId": {
          "type": "objectId",
          "label": "State-ID pH",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phDoseEnableStateId": {
          "type": "objectId",
          "label": "State-ID pH Freigabe",
          "objectTypes": [
            "state"
          ],
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpSocketStateId": {
          "type": "objectId",
          "label": "Dosierpumpe",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat PH-Dosierpumpe",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ]
        },
        "phPumpHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung der pH-Dosierpumpe."
        },
        "phPumpHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": true,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird die pH-Dosierpumpe als veraltet markiert. 0 = keine Prüfung."
        },
        "phControlHeader": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "phSetpoint": {
          "type": "text",
          "label": "pH Sollwert",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phCheckTimes": {
          "type": "text",
          "label": "pH Prüfzeiten",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "z. B. 11:00,15:00. Nur zu diesen Zeiten wird pH bewertet."
        },
        "phDoseTolerance": {
          "type": "text",
          "label": "pH Toleranz über Soll",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Dezimalwerte erlaubt, z. B. 0.05 oder 0,05."
        },
        "phDoseMode": {
          "type": "select",
          "label": "Modus PH-Dosierung",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "fest",
              "value": "fixed"
            },
            {
              "label": "berechnet (einfach)",
              "value": "calculated_simple"
            },
            {
              "label": "berechnet (ml-basiert)",
              "value": "calculated_ml"
            }
          ],
          "help": "fest = feste Laufzeit. berechnet (einfach) = Sekundenfaktor. berechnet (ml-basiert) = ml-Bedarf + Fördermenge."
        },
        "phFixedHeader": {
          "type": "header",
          "text": "Feste Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phDoseDurationSec": {
          "type": "text",
          "label": "Feste Dosierdauer je Prüfzeitpunkt (Sekunden)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Wird im Modus 'fest' exakt so verwendet.",
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phCalcHeader": {
          "type": "header",
          "text": "Berechnete Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phDoseSecondsPer01Per10m3": {
          "type": "text",
          "label": "Sekunden pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (einfach)'.",
          "hidden": "data.phDoseMode !== 'calculated_simple'"
        },
        "phDoseMlPer01Per10m3": {
          "type": "text",
          "label": "ml pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phPumpFlowMlPerMin": {
          "type": "text",
          "label": "Fördermenge Dosierpumpe (ml/min)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phDoseMaxDurationSec": {
          "type": "text",
          "label": "Max. Dosierdauer je Zyklus (Sekunden)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Maximale Dosierzeit pro Prüfzeitpunkt. Standard: 180 Sekunden.",
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phSafetyHeader": {
          "type": "header",
          "text": "Sicherheit",
          "size": 2
        },
        "phDoseLockMinutes": {
          "type": "text",
          "label": "Sperrzeit nach Dosierung (Minuten)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Nach einer Dosierung wird erst wieder beim nächsten Prüfzeitpunkt neu bewertet."
        },
        "phDoseMaxPerDay": {
          "type": "text",
          "label": "Max. Dosierungen pro Tag",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      },
      "hidden": "data.enablePhControl === false"
    },
