{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Prüfintervall (Minuten)",
          "newLine": true,
          "help": "Wie oft alle Werte neu gelesen und die HTML-Ausgabe aktualisiert wird."
        },
        "poolDiameterM": {
          "type": "text",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "z. B. 4.60 oder 4,60"
        },
        "poolWaterHeightM": {
          "type": "text",
          "label": "Wasserhöhe (m)",
          "newLine": true,
          "help": "z. B. 1.10 oder 1,10"
        },
        "poolVolumeM3": {
          "type": "text",
          "label": "Poolvolumen (m³)",
          "newLine": true,
          "help": "Wird beim Adapterstart / Poll neu berechnet.",
          "disabled": true
        },
        "enableCirculationControl": {
          "type": "checkbox",
          "label": "Umwälzpumpe aktiv",
          "newLine": true
        },
        "enablePhControl": {
          "type": "checkbox",
          "label": "PH Steuerung aktiv",
          "newLine": true
        },
        "enableHeatpumpControl": {
          "type": "checkbox",
          "label": "Wärmepumpensteuerung aktiv",
          "newLine": true
        },
        "enableChlorControl": {
          "type": "checkbox",
          "label": "Chlorsteuerung aktiv",
          "newLine": true
        }
      }
    },
    "circulation": {
      "type": "panel",
      "label": "UMWÄLZ-STEUERUNG",
      "items": {
        "circulationPumpSocketStateId": {
          "type": "text",
          "label": "Umwälzpumpe",
          "newLine": true
        },
        "pumpWindow1Start": {
          "type": "text",
          "label": "Zeitfenster 1 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow1End": {
          "type": "text",
          "label": "Zeitfenster 1 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2Start": {
          "type": "text",
          "label": "Zeitfenster 2 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2End": {
          "type": "text",
          "label": "Zeitfenster 2 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        }
      }
    },
    "chlor": {
      "type": "panel",
      "label": "CHLOR-STEUERUNG",
      "items": {
        "orpStateId": {
          "type": "text",
          "label": "State-ID ORP",
          "newLine": true
        },
        "chlorinatorSocketStateId": {
          "type": "text",
          "label": "Chlorinator",
          "newLine": true
        },
        "orpSetpoint": {
          "type": "number",
          "label": "ORP Sollwert",
          "newLine": true
        },
        "orpOnThreshold": {
          "type": "number",
          "label": "ORP Einschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP kleiner oder gleich diesem Wert ist, darf der Chlorinator einschalten."
        },
        "orpOffThreshold": {
          "type": "number",
          "label": "ORP Ausschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP größer als dieser Wert ist, wird der Chlorinator ausgeschaltet."
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH-STEUERUNG",
      "items": {
        "phStateId": {
          "type": "text",
          "label": "State-ID pH",
          "newLine": true
        },
        "phDoseEnableStateId": {
          "type": "text",
          "label": "State-ID pH Freigabe",
          "newLine": true
        },
        "phPumpSocketStateId": {
          "type": "text",
          "label": "Dosierpumpe",
          "newLine": true
        },
        "phSetpoint": {
          "type": "number",
          "label": "pH Sollwert",
          "newLine": true
        },
        "phCheckTimes": {
          "type": "text",
          "label": "pH Prüfzeiten",
          "newLine": true,
          "help": "z. B. 11:00,15:00. Nur zu diesen Zeiten wird pH bewertet."
        },
        "phDoseTolerance": {
          "type": "number",
          "label": "pH Toleranz über Soll",
          "newLine": true,
          "help": "Erst wenn pH größer als Soll + Toleranz ist, wird dosiert."
        },
        "phDoseDurationSec": {
          "type": "number",
          "label": "Dosierdauer je Zyklus (Sekunden)",
          "newLine": true,
          "help": "Laufzeit der Dosierpumpe pro aktivem Prüfzeitpunkt."
        },
        "phDoseLockMinutes": {
          "type": "number",
          "label": "Sperrzeit nach Dosierung (Minuten)",
          "newLine": true,
          "help": "Nach einer Dosierung wird bis zum Ablauf dieser Zeit nicht erneut dosiert."
        },
        "phDoseMaxPerDay": {
          "type": "number",
          "label": "Max. Dosierungen pro Tag",
          "newLine": true,
          "help": "Sicherheitsgrenze pro Kalendertag."
        },
        "phDoseSecondsPer01Per10m3": {
          "type": "number",
          "label": "Sekunden pro 0,1 pH je 10 m³",
          "newLine": true,
          "help": "Grundwert für die Laufzeitberechnung. Beispiel: 30 bedeutet 30s je 0,1 pH Abweichung bei 10 m³."
        },
        "phDoseMaxDurationSec": {
          "type": "number",
          "label": "Max. Dosierdauer je Zyklus (Sekunden)",
          "newLine": true,
          "help": "Obergrenze für die berechnete Dosierdauer."
        },
        "phDoseMlPer01Per10m3": {
          "type": "number",
          "label": "ml pro 0,1 pH je 10 m³",
          "newLine": true,
          "help": "Alternative, realitätsnähere Berechnung auf ml-Basis."
        },
        "phPumpFlowMlPerMin": {
          "type": "number",
          "label": "Fördermenge Dosierpumpe (ml/min)",
          "newLine": true,
          "help": "Wird genutzt, um aus ml eine Laufzeit in Sekunden zu berechnen."
        }
      }
    },
    "heat": {
      "type": "panel",
      "label": "WÄRMEPUMPEN-STEUERUNG",
      "items": {
        "waterTempStateId": {
          "type": "text",
          "label": "State-ID Wassertemperatur",
          "newLine": true
        },
        "outsideTempStateId": {
          "type": "text",
          "label": "State-ID Außentemperatur",
          "newLine": true
        },
        "heatpumpPowerStateId": {
          "type": "text",
          "label": "Wärmepumpe Power",
          "newLine": true
        },
        "heatpumpModeStateId": {
          "type": "text",
          "label": "Wärmepumpe Mode",
          "newLine": true
        },
        "heatpumpSetTempStateId": {
          "type": "text",
          "label": "Wärmepumpe Solltemperatur",
          "newLine": true
        },
        "heatpumpTargetTemp": {
          "type": "number",
          "label": "Solltemperatur",
          "newLine": true
        }
      }
    },
    "solar": {
      "type": "panel",
      "label": "SOLAR",
      "items": {
        "pvPowerStateId": {
          "type": "text",
          "label": "State-ID PV-Leistung",
          "newLine": true
        },
        "gridFeedInStateId": {
          "type": "text",
          "label": "State-ID Netzeinspeisung",
          "newLine": true
        },
        "gridSupplyStateId": {
          "type": "text",
          "label": "State-ID Netzbezug",
          "newLine": true
        },
        "batterySocStateId": {
          "type": "text",
          "label": "State-ID Batterie SoC",
          "newLine": true
        },
        "heatEnableFeedInThresholdW": {
          "type": "number",
          "label": "PV-Überschuss Schwellwert (W)",
          "newLine": true,
          "help": "Wenn die Netzeinspeisung größer als dieser Wert ist, darf die Wärmepumpe laufen."
        }
      }
    },
    "vis": {
      "type": "panel",
      "label": "VIS / HTML",
      "items": {
        "tabletInfo": {
          "type": "text",
          "label": "Tablet HTML-Objekt: poolsteuerung.0.vis.htmlTablet",
          "newLine": true,
          "disabled": true
        },
        "phoneInfo": {
          "type": "text",
          "label": "iPhone HTML-Objekt: poolsteuerung.0.vis.htmlPhone",
          "newLine": true,
          "disabled": true
        }
      }
    }
  }
}