        "phPumpSocketStateId": {
          "type": "text",
          "label": "Dosierpumpe",
          "newLine": true,
          "help": "Schaltbarer Datenpunkt der pH-Dosierpumpe."
        },
        "h2": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "phEnabled": {
          "type": "checkbox",
          "label": "pH aktiv",
          "newLine": true
        },
        "phTarget": {
          "type": "number",
          "label": "Soll-pH",
          "newLine": true
        },
        "phMinDelta": {
          "type": "number",
          "label": "Minimale Abweichung",
          "newLine": true
        },
        "phPumpFlowMlMin": {
          "type": "number",
          "label": "F\u00f6rdermenge ml/min",
          "newLine": true
        },
        "phLiquidFactorPercent": {
          "type": "number",
          "label": "Fl\u00fcssigfaktor %",
          "newLine": true
        },
        "phMaxDoseMlPerCycle": {
          "type": "number",
          "label": "Max ml pro Zyklus",
          "newLine": true
        },
        "phMaxRuntimeSec": {
          "type": "number",
          "label": "Max Laufzeit Sek",
          "newLine": true
        },
        "phOnlyWhenPumpRunning": {
          "type": "checkbox",
          "label": "Nur wenn Umw\u00e4lzpumpe l\u00e4uft",
          "newLine": true
        },
        "phDoseTimes": {
          "type": "text",
          "label": "Pr\u00fcfzeiten",
          "newLine": true,
          "help": "Kommagetrennte Uhrzeiten, z. B. 12:00,15:00."
        }
      }
    },
    "chlor": {
      "type": "panel",
