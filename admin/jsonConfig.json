{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Pr\u00fcfintervall (Minuten)",
          "newLine": true,
          "help": "Wie oft alle Werte neu gelesen und die HTML-Ausgabe aktualisiert wird."
        },
        "poolDiameterM": {
          "type": "text",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "z. B. 4.60 oder 4,60"
        },
        "poolWaterHeightM": {
          "type": "text",
          "label": "Wasserh\u00f6he (m)",
          "newLine": true,
          "help": "z. B. 1.10 oder 1,10"
        },
        "poolVolumeM3": {
          "type": "text",
          "label": "Poolvolumen (m\u00b3)",
          "newLine": true,
          "help": "Wird beim Adapterstart / Poll neu berechnet.",
          "disabled": true
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH-DOSIERUNG",
      "items": {
        "phStateId": {
          "type": "text",
          "label": "State-ID pH",
          "newLine": true
        },
        "phDoseEnableStateId": {
          "type": "text",
          "label": "State-ID pH Freigabe",
          "newLine": true
        },
        "phPumpSocketStateId": {
          "type": "text",
          "label": "Dosierpumpe",
          "newLine": true
        },
        "phSetpoint": {
          "type": "number",
          "label": "pH Sollwert",
          "newLine": true
        },
        "phCheckTimes": {
          "type": "text",
          "label": "pH Pr\u00fcfzeiten",
          "newLine": true,
          "help": "z. B. 11:00,15:00. Nur zu diesen Zeiten wird pH bewertet."
        },
        "phDoseTolerance": {
          "type": "number",
          "label": "pH Toleranz \u00fcber Soll",
          "newLine": true,
          "help": "Erst wenn pH gr\u00f6\u00dfer als Soll + Toleranz ist, wird dosiert."
        },
        "phDoseDurationSec": {
          "type": "number",
          "label": "Dosierdauer je Zyklus (Sekunden)",
          "newLine": true,
          "help": "Laufzeit der Dosierpumpe pro aktivem Pr\u00fcfzeitpunkt."
        },
        "phDoseLockMinutes": {
          "type": "number",
          "label": "Sperrzeit nach Dosierung (Minuten)",
          "newLine": true,
          "help": "Nach einer Dosierung wird bis zum Ablauf dieser Zeit nicht erneut dosiert."
        },
        "phDoseMaxPerDay": {
          "type": "number",
          "label": "Max. Dosierungen pro Tag",
          "newLine": true,
          "help": "Sicherheitsgrenze pro Kalendertag."
        },
        "phDoseSecondsPer01Per10m3": {
          "type": "number",
          "label": "Sekunden pro 0,1 pH je 10 m\u00b3",
          "newLine": true,
          "help": "Grundwert f\u00fcr die Laufzeitberechnung. Beispiel: 30 bedeutet 30s je 0,1 pH Abweichung bei 10 m\u00b3."
        },
        "phDoseMaxDurationSec": {
          "type": "number",
          "label": "Max. Dosierdauer je Zyklus (Sekunden)",
          "newLine": true,
          "help": "Obergrenze f\u00fcr die berechnete Dosierdauer."
        },
        "phDoseMlPer01Per10m3": {
          "type": "number",
          "label": "ml pro 0,1 pH je 10 m\u00b3",
          "newLine": true,
          "help": "Alternative, realit\u00e4tsn\u00e4here Berechnung auf ml-Basis."
        },
        "phPumpFlowMlPerMin": {
          "type": "number",
          "label": "F\u00f6rdermenge Dosierpumpe (ml/min)",
          "newLine": true,
          "help": "Wird genutzt, um aus ml eine Laufzeit in Sekunden zu berechnen."
        }
      }
    },
    "chlor": {
      "type": "panel",
      "label": "CHLORINATOR",
      "items": {
        "orpStateId": {
          "type": "text",
          "label": "State-ID ORP",
          "newLine": true
        },
        "chlorinatorSocketStateId": {
          "type": "text",
          "label": "Chlorinator",
          "newLine": true
        },
        "orpSetpoint": {
          "type": "number",
          "label": "ORP Sollwert",
          "newLine": true
        },
        "orpOnThreshold": {
          "type": "number",
          "label": "ORP Einschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP kleiner oder gleich diesem Wert ist, darf der Chlorinator einschalten."
        },
        "orpOffThreshold": {
          "type": "number",
          "label": "ORP Ausschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP gr\u00f6\u00dfer als dieser Wert ist, wird der Chlorinator ausgeschaltet."
        }
      }
    },
    "circulation": {
      "type": "panel",
      "label": "UMW\u00c4LZPUMPE",
      "items": {
        "circulationPumpSocketStateId": {
          "type": "text",
          "label": "Umw\u00e4lzpumpe",
          "newLine": true
        },
        "pumpWindow1Start": {
          "type": "text",
          "label": "Zeitfenster 1 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow1End": {
          "type": "text",
          "label": "Zeitfenster 1 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2Start": {
          "type": "text",
          "label": "Zeitfenster 2 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2End": {
          "type": "text",
          "label": "Zeitfenster 2 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        }
      }
    },
    "heat": {
      "type": "panel",
      "label": "W\u00c4RMEPUMPE",
      "items": {
        "waterTempStateId": {
          "type": "text",
          "label": "State-ID Wassertemperatur",
          "newLine": true
        },
        "outsideTempStateId": {
          "type": "text",
          "label": "State-ID Au\u00dfentemperatur",
          "newLine": true
        },
        "heatpumpPowerStateId": {
          "type": "text",
          "label": "W\u00e4rmepumpe Power",
          "newLine": true
        },
        "heatpumpModeStateId": {
          "type": "text",
          "label": "W\u00e4rmepumpe Mode",
          "newLine": true
        },
        "heatpumpSetTempStateId": {
          "type": "text",
          "label": "W\u00e4rmepumpe Solltemperatur",
          "newLine": true
        },
        "heatpumpTargetTemp": {
          "type": "number",
          "label": "Solltemperatur",
          "newLine": true
        }
      }
    },
    "solar": {
      "type": "panel",
      "label": "SOLAR",
      "items": {
        "pvPowerStateId": {
          "type": "text",
          "label": "State-ID PV-Leistung",
          "newLine": true
        },
        "gridFeedInStateId": {
          "type": "text",
          "label": "State-ID Netzeinspeisung",
          "newLine": true
        },
        "gridSupplyStateId": {
          "type": "text",
          "label": "State-ID Netzbezug",
          "newLine": true
        },
        "batterySocStateId": {
          "type": "text",
          "label": "State-ID Batterie SoC",
          "newLine": true
        },
        "heatEnableFeedInThresholdW": {
          "type": "number",
          "label": "PV-\u00dcberschuss Schwellwert (W)",
          "newLine": true,
          "help": "Wenn die Netzeinspeisung gr\u00f6\u00dfer als dieser Wert ist, darf die W\u00e4rmepumpe laufen."
        }
      }
    },
    "vis": {
      "type": "panel",
      "label": "VIS / HTML",
      "items": {
        "tabletInfo": {
          "type": "text",
          "label": "Tablet HTML-Objekt: poolsteuerung.0.vis.htmlTablet",
          "newLine": true,
          "disabled": true
        },
        "phoneInfo": {
          "type": "text",
          "label": "iPhone HTML-Objekt: poolsteuerung.0.vis.htmlPhone",
          "newLine": true,
          "disabled": true
        }
      }
    }
  }
}