{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Prüfintervall (Minuten)",
          "newLine": true,
          "help": "Wie oft alle Werte neu gelesen und die HTML-Ausgabe aktualisiert wird."
        },
        "poolDiameterM": {
          "type": "text",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "z. B. 4.60 oder 4,60"
        },
        "poolWaterHeightM": {
          "type": "text",
          "label": "Wasserhöhe (m)",
          "newLine": true,
          "help": "z. B. 1.10 oder 1,10"
        },
        "poolVolumeM3": {
          "type": "text",
          "label": "Poolvolumen (m³)",
          "newLine": true,
          "help": "Wird beim Adapterstart / Poll neu berechnet.",
          "disabled": true
        },
        "enableCirculationControl": {
          "type": "checkbox",
          "label": "Umwälzpumpe aktiv",
          "newLine": true
        },
        "enablePhControl": {
          "type": "checkbox",
          "label": "PH Steuerung aktiv",
          "newLine": true
        },
        "enableHeatpumpControl": {
          "type": "checkbox",
          "label": "Wärmepumpensteuerung aktiv",
          "newLine": true
        },
        "enableChlorControl": {
          "type": "checkbox",
          "label": "Chlorsteuerung aktiv",
          "newLine": true
        }
      }
    },
    "circulation": {
      "type": "panel",
      "label": "UMWÄLZ-STEUERUNG",
      "items": {
        "circStatesHeader": {
          "type": "header",
          "text": "Pumpendatenpunkte",
          "size": 2
        },
        "circulationPumpSocketStateId": {
          "type": "objectId",
          "label": "Objekt-ID Pumpensteckdose",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "circulationPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat Umwälzpumpe",
          "newLine": false,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "circScheduleHeader": {
          "type": "header",
          "text": "Zeitfenster",
          "size": 2
        },
        "circulationWindow1Start": {
          "type": "text",
          "label": "Zeitfenster 1 Start",
          "sm": 12,
          "md": 6,
          "lg": 6,
          "newLine": true
        },
        "circulationWindow1End": {
          "type": "text",
          "label": "Zeitfenster 1 Ende",
          "sm": 12,
          "md": 6,
          "lg": 6,
          "newLine": false
        },
        "circulationWindow2Start": {
          "type": "text",
          "label": "Zeitfenster 2 Start",
          "sm": 12,
          "md": 6,
          "lg": 6,
          "newLine": true
        },
        "circulationWindow2End": {
          "type": "text",
          "label": "Zeitfenster 2 Ende",
          "sm": 12,
          "md": 6,
          "lg": 6,
          "newLine": false
        },
        "circInfoHeader": {
          "type": "header",
          "text": "Hinweise",
          "size": 2
        },
        "circInfoText": {
          "type": "staticText",
          "text": "00:00 bis 00:00 = inaktiv. Die Pumpe wird nur bei echtem Zeitfensterwechsel automatisch geschaltet.",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12
        }
      }
    },
    "chlor": {
      "type": "panel",
      "label": "CHLOR-STEUERUNG",
      "items": {
        "chlorStatesHeader": {
          "type": "header",
          "text": "Sensordaten und Aktor",
          "size": 2
        },
        "orpStateId": {
          "type": "objectId",
          "label": "State-ID ORP / Redox",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "chlorinatorSocketStateId": {
          "type": "objectId",
          "label": "Chlorinator",
          "objectTypes": [
            "state"
          ],
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "chlorinatorWriteMode": {
          "type": "select",
          "label": "Schreibformat Chlorinator",
          "newLine": true,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "chlorRulesHeader": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "orpOnThreshold": {
          "type": "number",
          "label": "ORP Einschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP kleiner oder gleich diesem Wert ist, darf der Chlorinator einschalten.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "orpOffThreshold": {
          "type": "number",
          "label": "ORP Ausschaltgrenze",
          "newLine": false,
          "help": "Wenn ORP größer als dieser Wert ist, wird der Chlorinator ausgeschaltet.",
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "chlorOnDelaySec": {
          "type": "text",
          "label": "Einschaltverzögerung (Sekunden)",
          "sm": 12,
          "md": 6,
          "lg": 6,
          "newLine": true
        },
        "chlorInfoHeader": {
          "type": "header",
          "text": "Hinweise",
          "size": 2
        },
        "chlorInfoText": {
          "type": "staticText",
          "text": "Der Chlorinator läuft nur mit aktiver Umwälzpumpe. Zwischen Ein- und Ausschaltgrenze bleibt die Hysterese stabil.",
          "newLine": true,
          "sm": 12,
          "md": 12,
          "lg": 12
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH-STEUERUNG",
      "items": {
        "phSensorsHeader": {
          "type": "header",
          "text": "Sensordaten und Freigaben",
          "size": 2
        },
        "phStateId": {
          "type": "objectId",
          "label": "State-ID pH",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phDoseEnableStateId": {
          "type": "objectId",
          "label": "State-ID pH Freigabe",
          "objectTypes": [
            "state"
          ],
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpSocketStateId": {
          "type": "objectId",
          "label": "Dosierpumpe",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat PH-Dosierpumpe",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ]
        },
        "phControlHeader": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "phSetpoint": {
          "type": "text",
          "label": "pH Sollwert",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phCheckTimes": {
          "type": "text",
          "label": "pH Prüfzeiten",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "z. B. 11:00,15:00. Nur zu diesen Zeiten wird pH bewertet."
        },
        "phDoseTolerance": {
          "type": "text",
          "label": "pH Toleranz über Soll",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Dezimalwerte erlaubt, z. B. 0.05 oder 0,05."
        },
        "phDoseMode": {
          "type": "select",
          "label": "Modus PH-Dosierung",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "fest",
              "value": "fixed"
            },
            {
              "label": "berechnet (einfach)",
              "value": "calculated_simple"
            },
            {
              "label": "berechnet (ml-basiert)",
              "value": "calculated_ml"
            }
          ],
          "help": "fest = feste Laufzeit. berechnet (einfach) = Sekundenfaktor. berechnet (ml-basiert) = ml-Bedarf + Fördermenge."
        },
        "phFixedHeader": {
          "type": "header",
          "text": "Feste Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phDoseDurationSec": {
          "type": "text",
          "label": "Feste Dosierdauer je Prüfzeitpunkt (Sekunden)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Wird im Modus 'fest' exakt so verwendet.",
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phCalcHeader": {
          "type": "header",
          "text": "Berechnete Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phDoseSecondsPer01Per10m3": {
          "type": "text",
          "label": "Sekunden pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (einfach)'.",
          "hidden": "data.phDoseMode !== 'calculated_simple'"
        },
        "phDoseMlPer01Per10m3": {
          "type": "text",
          "label": "ml pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phPumpFlowMlPerMin": {
          "type": "text",
          "label": "Fördermenge Dosierpumpe (ml/min)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phDoseMaxDurationSec": {
          "type": "text",
          "label": "Max. Dosierdauer je Zyklus (Sekunden)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Maximale Dosierzeit pro Prüfzeitpunkt. Standard: 180 Sekunden.",
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phSafetyHeader": {
          "type": "header",
          "text": "Sicherheit",
          "size": 2
        },
        "phDoseLockMinutes": {
          "type": "text",
          "label": "Sperrzeit nach Dosierung (Minuten)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Nach einer Dosierung wird erst wieder beim nächsten Prüfzeitpunkt neu bewertet."
        },
        "phDoseMaxPerDay": {
          "type": "text",
          "label": "Max. Dosierungen pro Tag",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      }
    },
    "heat": {
      "type": "panel",
      "label": "WÄRMEPUMPEN-STEUERUNG",
      "items": {
        "waterTempStateId": {
          "type": "text",
          "label": "State-ID Wassertemperatur",
          "newLine": true
        },
        "outsideTempStateId": {
          "type": "text",
          "label": "State-ID Außentemperatur",
          "newLine": true
        },
        "heatpumpPowerStateId": {
          "type": "text",
          "label": "Wärmepumpe Power",
          "newLine": true
        },
        "heatpumpModeStateId": {
          "type": "text",
          "label": "Wärmepumpe Mode",
          "newLine": true
        },
        "heatpumpSetTempStateId": {
          "type": "text",
          "label": "Wärmepumpe Solltemperatur",
          "newLine": true
        },
        "heatpumpTargetTemp": {
          "type": "number",
          "label": "Solltemperatur",
          "newLine": true
        }
      }
    },
    "solar": {
      "type": "panel",
      "label": "SOLAR",
      "items": {
        "pvPowerStateId": {
          "type": "text",
          "label": "State-ID PV-Leistung",
          "newLine": true
        },
        "gridFeedInStateId": {
          "type": "text",
          "label": "State-ID Netzeinspeisung",
          "newLine": true
        },
        "gridSupplyStateId": {
          "type": "text",
          "label": "State-ID Netzbezug",
          "newLine": true
        },
        "batterySocStateId": {
          "type": "text",
          "label": "State-ID Batterie SoC",
          "newLine": true
        },
        "heatEnableFeedInThresholdW": {
          "type": "number",
          "label": "PV-Überschuss Schwellwert (W)",
          "newLine": true,
          "help": "Wenn die Netzeinspeisung größer als dieser Wert ist, darf die Wärmepumpe laufen."
        }
      }
    },
    "vis": {
      "type": "panel",
      "label": "VIS / HTML",
      "items": {
        "tabletInfo": {
          "type": "text",
          "label": "Tablet HTML-Objekt: poolsteuerung.0.vis.htmlTablet",
          "newLine": true,
          "disabled": true
        },
        "phoneInfo": {
          "type": "text",
          "label": "iPhone HTML-Objekt: poolsteuerung.0.vis.htmlPhone",
          "newLine": true,
          "disabled": true
        }
      }
    }
  }
}