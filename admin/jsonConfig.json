    "status": {
      "type": "panel",
      "label": "STATUS",
      "items": {
        "h1": {
          "type": "header",
          "text": "Hinweis",
          "size": 2
        },
        "i1": {
          "type": "staticText",
          "text": "Dieser Reiter ist als \u00dcbersicht gedacht. Die Live-Werte kommen aktuell aus dem Objektbaum unter poolsteuerung.0.status.*",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 8
          }
        },
        "s1": {
          "type": "text",
          "label": "Status pH Vorschau ml",
          "newLine": true,
          "help": "Objekt: poolsteuerung.0.status.ph.previewMl",
          "disabled": true
        },
        "s2": {
          "type": "text",
          "label": "Status Chlorinator letzte Aktion",
          "newLine": true,
          "help": "Objekt: poolsteuerung.0.status.chlorinator.lastAction",
          "disabled": true
        },
        "s3": {
          "type": "text",
          "label": "Status Umw\u00e4lzpumpe letzte Aktion",
          "newLine": true,
          "help": "Objekt: poolsteuerung.0.status.pump.lastAction",
          "disabled": true
        },
        "s4": {
          "type": "text",
          "label": "Status W\u00e4rmepumpe Grund",
          "newLine": true,
          "help": "Objekt: poolsteuerung.0.status.heatpump.lastReason",
          "disabled": true
        },
        "s5": {
          "type": "text",
          "label": "Status letzter Zyklus",
          "newLine": true,
          "help": "Objekt: poolsteuerung.0.status.debug.lastCycle",
