{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Prüfintervall (Minuten)",
          "newLine": true,
          "help": "Wie oft alle Werte neu gelesen und die HTML-Ausgabe aktualisiert wird."
        },
        "poolDiameterM": {
          "type": "text",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "z. B. 4.60 oder 4,60"
        },
        "poolWaterHeightM": {
          "type": "text",
          "label": "Wasserhöhe (m)",
          "newLine": true,
          "help": "z. B. 1.10 oder 1,10"
        },
        "poolVolumeM3": {
          "type": "text",
          "label": "Poolvolumen (m³)",
          "newLine": true,
          "help": "Wird beim Adapterstart / Poll neu berechnet.",
          "disabled": true
        },
        "enableCirculationControl": {
          "type": "checkbox",
          "label": "Umwälzpumpe aktiv",
          "newLine": true
        },
        "enablePhControl": {
          "type": "checkbox",
          "label": "PH Steuerung aktiv",
          "newLine": true
        },
        "enableHeatpumpControl": {
          "type": "checkbox",
          "label": "Wärmepumpensteuerung aktiv",
          "newLine": true
        },
        "enableChlorControl": {
          "type": "checkbox",
          "label": "Chlorsteuerung aktiv",
          "newLine": true
        }
      }
    },
    "circulation": {
      "type": "panel",
      "label": "UMWÄLZPUMPE",
      "items": {
        "circulationPumpSocketStateId": {
          "type": "text",
          "label": "Umwälzpumpe",
          "newLine": true
        },
        "circulationPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat Umwälzpumpe",
          "newLine": true,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet."
        },
        "circulationPumpHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung, z. B. ein regelmäßig aktualisierter Temperatur- oder Status-State."
        },
        "circulationPumpHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": true,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird das Gerät als veraltet markiert. 0 = keine Prüfung."
        },
        "pumpWindow1Start": {
          "type": "text",
          "label": "Zeitfenster 1 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow1End": {
          "type": "text",
          "label": "Zeitfenster 1 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2Start": {
          "type": "text",
          "label": "Zeitfenster 2 Start",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        },
        "pumpWindow2End": {
          "type": "text",
          "label": "Zeitfenster 2 Ende",
          "newLine": true,
          "help": "Format HH:MM. 00:00 bis 00:00 = inaktiv."
        }
      }
    },
    "chlor": {
      "type": "panel",
      "label": "CHLOR",
      "items": {
        "orpStateId": {
          "type": "text",
          "label": "State-ID ORP",
          "newLine": true
        },
        "chlorinatorSocketStateId": {
          "type": "text",
          "label": "Chlorinator",
          "newLine": true
        },
        "chlorinatorWriteMode": {
          "type": "select",
          "label": "Schreibformat Chlorinator",
          "newLine": true,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ],
          "help": "Legt fest, wie der Adapter den Aktor schaltet."
        },
        "chlorPumpStartDelaySec": {
          "type": "number",
          "label": "Verzögerung nach Pumpenstart (Sekunden)",
          "newLine": true,
          "min": 0,
          "help": "Der Chlorinator darf erst nach dieser Verzögerung nach dem Einschalten der Umwälzpumpe aktiv werden. 0 = ohne Verzögerung."
        },
        "chlorinatorHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung des Chlorinators."
        },
        "chlorinatorHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": true,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird der Chlorinator als veraltet markiert. 0 = keine Prüfung."
        },
        "orpSetpoint": {
          "type": "number",
          "label": "ORP Sollwert",
          "newLine": true
        },
        "orpOnThreshold": {
          "type": "number",
          "label": "ORP Einschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP kleiner oder gleich diesem Wert ist, darf der Chlorinator einschalten."
        },
        "orpOffThreshold": {
          "type": "number",
          "label": "ORP Ausschaltgrenze",
          "newLine": true,
          "help": "Wenn ORP größer als dieser Wert ist, wird der Chlorinator ausgeschaltet."
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH",
      "items": {
        "phSensorsHeader": {
          "type": "header",
          "text": "Sensordaten und Freigaben",
          "size": 2
        },
        "phStateId": {
          "type": "objectId",
          "label": "State-ID pH",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phDoseEnableStateId": {
          "type": "objectId",
          "label": "State-ID pH Freigabe",
          "objectTypes": [
            "state"
          ],
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpSocketStateId": {
          "type": "objectId",
          "label": "Dosierpumpe",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phPumpWriteMode": {
          "type": "select",
          "label": "Schreibformat PH-Dosierpumpe",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "false / true",
              "value": "bool"
            },
            {
              "label": "0 / 1",
              "value": "num01"
            }
          ]
        },
        "phPumpHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung der pH-Dosierpumpe."
        },
        "phPumpHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": true,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird die pH-Dosierpumpe als veraltet markiert. 0 = keine Prüfung."
        },
        "phControlHeader": {
          "type": "header",
          "text": "Regelung",
          "size": 2
        },
        "phSetpoint": {
          "type": "text",
          "label": "pH Sollwert",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6
        },
        "phCheckTimes": {
          "type": "text",
          "label": "pH Prüfzeiten",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "z. B. 11:00,15:00. Nur zu diesen Zeiten wird pH bewertet."
        },
        "phDoseTolerance": {
          "type": "text",
          "label": "pH Toleranz über Soll",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Dezimalwerte erlaubt, z. B. 0.05 oder 0,05."
        },
        "phDoseMode": {
          "type": "select",
          "label": "Modus PH-Dosierung",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "options": [
            {
              "label": "fest",
              "value": "fixed"
            },
            {
              "label": "berechnet (einfach)",
              "value": "calculated_simple"
            },
            {
              "label": "berechnet (ml-basiert)",
              "value": "calculated_ml"
            }
          ],
          "help": "fest = feste Laufzeit. berechnet (einfach) = Sekundenfaktor. berechnet (ml-basiert) = ml-Bedarf + Fördermenge."
        },
        "phFixedHeader": {
          "type": "header",
          "text": "Feste Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phDoseDurationSec": {
          "type": "text",
          "label": "Feste Dosierdauer je Prüfzeitpunkt (Sekunden)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Wird im Modus 'fest' exakt so verwendet.",
          "hidden": "data.phDoseMode !== 'fixed'"
        },
        "phCalcHeader": {
          "type": "header",
          "text": "Berechnete Dosierung",
          "size": 2,
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phDoseSecondsPer01Per10m3": {
          "type": "text",
          "label": "Sekunden pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (einfach)'.",
          "hidden": "data.phDoseMode !== 'calculated_simple'"
        },
        "phDoseMlPer01Per10m3": {
          "type": "text",
          "label": "ml pro 0,1 pH je 10 m³",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phPumpFlowMlPerMin": {
          "type": "text",
          "label": "Fördermenge Dosierpumpe (ml/min)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Für Modus 'berechnet (ml-basiert)'.",
          "hidden": "data.phDoseMode !== 'calculated_ml'"
        },
        "phDoseMaxDurationSec": {
          "type": "text",
          "label": "Max. Dosierdauer je Zyklus (Sekunden)",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Maximale Dosierzeit pro Prüfzeitpunkt. Standard: 180 Sekunden.",
          "hidden": "data.phDoseMode === 'fixed'"
        },
        "phSafetyHeader": {
          "type": "header",
          "text": "Sicherheit",
          "size": 2
        },
        "phDoseLockMinutes": {
          "type": "text",
          "label": "Sperrzeit nach Dosierung (Minuten)",
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Nach einer Dosierung wird erst wieder beim nächsten Prüfzeitpunkt neu bewertet."
        },
        "phDoseMaxPerDay": {
          "type": "text",
          "label": "Max. Dosierungen pro Tag",
          "newLine": false,
          "sm": 12,
          "md": 6,
          "lg": 6
        }
      }
    },
    "heat": {
      "type": "panel",
      "label": "WÄRMEPUMPE",
      "items": {
        "waterTempStateId": {
          "type": "text",
          "label": "State-ID Wassertemperatur",
          "newLine": true
        },
        "outsideTempStateId": {
          "type": "text",
          "label": "State-ID Außentemperatur",
          "newLine": true
        },
        "heatpumpPowerStateId": {
          "type": "text",
          "label": "Wärmepumpe Power",
          "newLine": true
        },
        "heatpumpHeartbeatStateId": {
          "type": "objectId",
          "label": "Heartbeat-State-ID",
          "objectTypes": [
            "state"
          ],
          "newLine": true,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "help": "Optionaler State zur Erreichbarkeitsprüfung der Wärmepumpe."
        },
        "heatpumpHeartbeatMaxAgeMin": {
          "type": "number",
          "label": "Max. Alter Heartbeat (Minuten)",
          "newLine": true,
          "help": "Wenn der Heartbeat älter ist als dieser Wert, wird die Wärmepumpe als veraltet markiert. 0 = keine Prüfung."
        },
        "heatpumpModeStateId": {
          "type": "text",
          "label": "Wärmepumpe Mode",
          "newLine": true
        },
        "heatpumpSetTempStateId": {
          "type": "text",
          "label": "Wärmepumpe Solltemperatur",
          "newLine": true
        },
        "heatpumpTargetTemp": {
          "type": "number",
          "label": "Solltemperatur",
          "newLine": true
        }
      }
    },
    "solar": {
      "type": "panel",
      "label": "SOLAR",
      "items": {
        "pvPowerStateId": {
          "type": "text",
          "label": "State-ID PV-Leistung",
          "newLine": true
        },
        "gridFeedInStateId": {
          "type": "text",
          "label": "State-ID Netzeinspeisung",
          "newLine": true
        },
        "gridSupplyStateId": {
          "type": "text",
          "label": "State-ID Netzbezug",
          "newLine": true
        },
        "batterySocStateId": {
          "type": "text",
          "label": "State-ID Batterie SoC",
          "newLine": true
        },
        "heatEnableFeedInThresholdW": {
          "type": "number",
          "label": "PV-Überschuss Schwellwert (W)",
          "newLine": true,
          "help": "Wenn die Netzeinspeisung größer als dieser Wert ist, darf die Wärmepumpe laufen."
        }
      }
    },
    "alerts": {
      "type": "panel",
      "label": "ALERTS",
      "items": {
        "enableAlerts": {
          "type": "checkbox",
          "label": "Alerts aktiv",
          "newLine": true,
          "help": "Benachrichtigungen werden nur gesendet, wenn zusätzlich unter ALLGEMEIN der Adapter aktiv ist."
        },
        "alertRepeatLockMin": {
          "type": "number",
          "label": "Wiederholsperre je Meldung (Minuten)",
          "newLine": true,
          "help": "Verhindert identische Benachrichtigungen in zu kurzen Abständen."
        },
        "alertWhatsappEnabled": {
          "type": "checkbox",
          "label": "WhatsApp aktiv",
          "newLine": true
        },
        "alertWhatsappInstance": {
          "type": "text",
          "label": "WhatsApp Instanz",
          "newLine": true,
          "help": "Zum Beispiel open-wa.0"
        },
        "alertWhatsappTo": {
          "type": "text",
          "label": "WhatsApp Empfänger",
          "newLine": true,
          "help": "Empfänger oder Ziel-ID für den konfigurierten Adapter."
        },
        "alertTelegramEnabled": {
          "type": "checkbox",
          "label": "Telegram aktiv",
          "newLine": true
        },
        "alertTelegramInstance": {
          "type": "text",
          "label": "Telegram Instanz",
          "newLine": true,
          "help": "Zum Beispiel telegram.0"
        },
        "alertTelegramTo": {
          "type": "text",
          "label": "Telegram Empfänger / Chat-ID",
          "newLine": true
        },
        "alertEmailEnabled": {
          "type": "checkbox",
          "label": "E-Mail aktiv",
          "newLine": true
        },
        "alertEmailInstance": {
          "type": "text",
          "label": "E-Mail Instanz",
          "newLine": true,
          "help": "Zum Beispiel email.0"
        },
        "alertEmailTo": {
          "type": "text",
          "label": "E-Mail Empfänger",
          "newLine": true
        },
        "alertOnPhDoseStarted": {
          "type": "checkbox",
          "label": "Bei pH-Dosierung gestartet",
          "newLine": true
        },
        "alertOnPhDoseStopped": {
          "type": "checkbox",
          "label": "Bei pH-Dosierung beendet",
          "newLine": true
        },
        "alertOnPhDoseAborted": {
          "type": "checkbox",
          "label": "Bei pH-Dosierung abgebrochen",
          "newLine": true
        },
        "alertOnPhDailyLimit": {
          "type": "checkbox",
          "label": "Bei Tageslimit pH-Dosierung",
          "newLine": true
        },
        "alertOnSensorError": {
          "type": "checkbox",
          "label": "Bei Sensorfehler / ungültigen Werten",
          "newLine": true
        },
        "alertOnPollError": {
          "type": "checkbox",
          "label": "Bei Adapter- oder Poll-Fehlern",
          "newLine": true
        }
      }
    }
  }
}