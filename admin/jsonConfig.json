{
  "type": "tabs",
  "width": "900px",
  "items": {
    "general": {
      "type": "panel",
      "label": "ALLGEMEIN",
      "items": {
        "h1": {
          "type": "header",
          "text": "Pooldaten",
          "size": 2
        },
        "i1": {
          "type": "staticText",
          "text": "Durchmesser und Wasserh\u00f6he bestimmen das Poolvolumen.",
          "style": {
            "opacity": 0.8,
            "fontSize": 12,
            "paddingBottom": 8
          }
        },
        "poolDiameterM": {
          "type": "number",
          "label": "Pooldurchmesser (m)",
          "newLine": true,
          "help": "Innendurchmesser des Pools."
        },
        "poolWaterHeightM": {
          "type": "number",
          "label": "Wasserh\u00f6he (m)",
          "newLine": true,
          "help": "Aktuelle Wasserh\u00f6he."
        },
        "poolVolumeM3": {
          "type": "number",
          "label": "Poolvolumen (m\u00b3)",
          "newLine": true,
          "help": "Automatisch berechneter Richtwert.",
          "disabled": true
        },
        "h2": {
          "type": "header",
          "text": "Adapter",
          "size": 2
        },
        "adapterEnabled": {
          "type": "checkbox",
          "label": "Adapter aktiv",
          "newLine": true,
          "help": "Schaltet die komplette Poolautomatik ein oder aus."
        },
        "debugMode": {
          "type": "checkbox",
          "label": "Debug-Modus",
          "newLine": true,
          "help": "Schreibt zus\u00e4tzliche Entscheidungen und Werte ins Log."
        },
        "simulateMode": {
          "type": "checkbox",
          "label": "Simulationsmodus",
          "newLine": true,
          "help": "Es werden keine echten Aktoren geschaltet."
        },
        "pollIntervalMin": {
          "type": "number",
          "label": "Pr\u00fcfintervall (Minuten)",
          "newLine": true,
          "help": "Zeitabstand zwischen den Steuerzyklen."
        }
      }
    },
    "ph": {
      "type": "panel",
      "label": "PH-DOSIERUNG",
      "items": {
        "h1": {
          "type": "header",
          "text": "Sensor & Aktor",
          "size": 2
        },
        "phStateId": {
          "type": "text",
          "label": "State-ID pH",
          "newLine": true,
          "help": "Datenpunkt f\u00fcr den aktuellen pH-Wert."
        },
        "phDoseEnableStateId": {
          "type": "text",
          "label": "State-ID pH Freigabe",
          "newLine": true,
          "help": "Boolescher Freigabe-Datenpunkt f\u00fcr die Dosierung."
